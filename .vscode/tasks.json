{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar",
            "type": "shell",
            "command": "make",
            "args": [
                "BUILD=release"
            ],
            "group": {"kind":"build", "isDefault": true}
        },
        {
            "label": "Compilar (ASAN)",
            "type": "shell",
            "command": "make",
            "args": ["INSPECTOR=asan"],
            "problemMatcher": []
        },
        {
            "label": "Compilar (VALGRIND)",
            "type": "shell",
            "command": "make",
            "args": ["INSPECTOR=valgrind"],
            "problemMatcher": []
        },
        {
            "label": "Limpiar",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "problemMatcher": []
        },
        {
            "label": "Ejecutar test (ASAN)",
            "type": "shell",
            "command": "make",
            "args": [
                "runTest",
                "INSPECTOR=asan"
            ],
            "problemMatcher": []
        },
        {
            "label": "Ejecutar test (VALGRIND)",
            "type": "shell",
            "command": "make",
            "args": [
                "runTest",
                "INSPECTOR=valgrind"
            ],
            "problemMatcher": []
        },
        {
            "label": "Ejecutar Deployment",
            "type": "shell",
            "dependsOrder": "sequence",
            "dependsOn": ["Compilar"],
            "command": "make",
            "args": ["runDeployment"],
            "problemMatcher": []
        },
    ]
}